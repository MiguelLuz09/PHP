<?php
$editando = false;
$indiceEditar = null;
$contaEditar = null;

session_start();

if (isset($_GET["editar"])) {

    $indiceEditar = $_GET["editar"];
    $contaEditar = $_SESSION["contas"][$indiceEditar];

    $editando = true;
}

if (isset($_GET["excluir"])) {

    $index = $_GET["excluir"];

    unset($_SESSION["contas"][$index]);

    $_SESSION["contas"] = array_values($_SESSION["contas"]);

    header("Location: NovaConta.php");
    exit;
}
if (!isset($_SESSION["contas"])) {
    $_SESSION["contas"] = [];
}
$mensagem = "";

if ($_SERVER["REQUEST_METHOD"] == "POST") {

    $nome = $_POST["nome"];
    $descricao = $_POST["descricao"];
    $valor = $_POST["valor"];
    $tipo = $_POST["tipo"];

    $mensagem = "Conta cadastrada com sucesso!";

    if (isset($_POST["indice"])) {

        $indiceEditar = $_POST["indice"];

        $_SESSION["contas"][$indiceEditar] = [
            "nome" => $nome,
            "descricao" => $descricao,
            "valor" => $valor,
            "tipo" => $tipo
        ];

    } else {

        $_SESSION["contas"][] = [
            "nome" => $nome,
            "descricao" => $descricao,
            "valor" => $valor,
            "tipo" => $tipo
        ];
    }
    header("Location: NovaConta.php");
    exit;
}
?>

<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <title>Nova Conta</title>
    <link rel="stylesheet" href="style.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>
    <div class="container mt-5">

        <h2 class="mb-4">Nova Conta</h2>

        <?php if ($mensagem != "") { ?>
            <div class="alert alert-success">
                <?php echo $mensagem; ?>
            </div>
        <?php } ?>

        <form method="POST">

            <div class="mb-3">
                <label class="form-label">Nome</label>
                <input type="text" name="nome" class="form-control"
                    value="<?= $editando ? $contaEditar["nome"] : '' ?>">
            </div>

            <div class="mb-3">
                <label class="form-label">Descrição</label>
                <input type="text" name="descricao" class="form-control"
                    value="<?= $editando ? $contaEditar["descricao"] : '' ?>">
            </div>

            <div class="mb-3">
                <label class="form-label">Valor</label>
                <input type="number" step="0.01" name="valor" class="form-control"
                    value="<?= $editando ? $contaEditar["valor"] : '' ?>">
            </div>

            <div class="mb-3">
                <label class="form-label">Tipo</label>
                <select name="tipo" class="form-control">

                    <option value="Receber" <?= ($editando && $contaEditar["tipo"] == "Receber") ? "selected" : "" ?>>
                        Receber
                    </option>

                    <option value="Pagar" <?= ($editando && $contaEditar["tipo"] == "Pagar") ? "selected" : "" ?>>
                        Pagar
                    </option>

                </select>
            </div>

            <button type="submit" class="btn btn-primary">
                Salvar
            </button>

            <?php if ($editando) { ?>
                <input type="hidden" name="indice" value="<?= $indiceEditar ?>">
            <?php } ?>

        </form>
        <?php if (!empty($_SESSION["contas"])) { ?>

            <h3 class="mt-4">Contas cadastradas:</h3>

            <table class="table table-bordered table-striped mt-3">

                <tr class="table-dark">
                    <th>Nome</th>
                    <th>Descrição</th>
                    <th>Valor</th>
                    <th>Tipo</th>
                    <th>Ações</th>
                </tr>

                <?php foreach ($_SESSION["contas"] as $index => $conta) { ?>
                    <tr>
                        <td><?= $conta["nome"] ?></td>

                        <td><?= $conta["descricao"] ?></td>

                        <td>R$ <?= $conta["valor"] ?></td>

                        <td class="<?= strtolower($conta["tipo"]) ?>">
                            <?= $conta["tipo"] ?>
                        </td>

                        <td>
                            <a href="?editar=<?= $index ?>" class="btn btn-warning btn-sm">
                                Editar
                            </a>

                            <a href="?excluir=<?= $index ?>" class="btn btn-danger btn-sm">
                                Excluir
                            </a>
                        </td>
                    </tr>
                <?php } ?>

            </table>

        <?php } ?>

    </div>
</body>

</html>
